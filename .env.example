# Cloudflare Pages deploys only, token zone-scoped to machtblick.de
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional SQLite path override, defaults to db/machtblick.sqlite
MACHTBLICK_DB=

# Optional, etl:dip falls back to the public documented DIP key
DIP_API_KEY=

# iOS TestFlight uploads only (fastlane ios beta_local)
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_CONTENT=
TESTFLIGHT_PUBLIC_GROUP=
