require "shellwords"

APP_VERSION = File.read(
  File.expand_path("../apps/ios/Config/Version.xcconfig", __dir__)
).match(/^MARKETING_VERSION = (.+)$/)[1]

default_platform(:ios)

platform :ios do
  desc "Build and upload iOS app to TestFlight"
  lane :beta_local do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "soli.Machtblick"
    )
    build_number += 1
    increment_build_number(
      xcodeproj: "apps/ios/iOS.xcodeproj",
      build_number: build_number
    )
    File.open(ENV["GITHUB_ENV"], "a") do |file|
      file.puts("TESTFLIGHT_BUILD_NUMBER=#{build_number}")
    end if ENV["CI"]

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "apps/ios/iOS.xcodeproj",
      team_id: "Q9U8224WWM",
      targets: ["Machtblick"]
    )

    auth_xcargs = ""
    if ENV["CI"]
      key_path = File.join(ENV.fetch("RUNNER_TEMP"), "AuthKey.p8")
      File.write(key_path, ENV["APP_STORE_CONNECT_API_KEY_CONTENT"])
      auth_xcargs = "-authenticationKeyID #{ENV["APP_STORE_CONNECT_API_KEY_ID"]} -authenticationKeyIssuerID #{ENV["APP_STORE_CONNECT_API_ISSUER_ID"]} -authenticationKeyPath #{Shellwords.escape(key_path)}"
    end

    build_app(
      project: "apps/ios/iOS.xcodeproj",
      scheme: "Machtblick",
      xcargs: "-allowProvisioningUpdates #{auth_xcargs}",
      export_method: "app-store",
      export_xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: "Q9U8224WWM"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      distribute_external: true,
      groups: [ENV.fetch("TESTFLIGHT_PUBLIC_GROUP")],
      notify_external_testers: true,
      changelog: "Neu: Ein Tipp auf das Machtblick-Logo springt zum Seitenanfang.",
      localized_build_info: {
        "de-DE": {
          whats_new: "Ein Tipp auf das Machtblick-Logo springt jetzt zum Seitenanfang."
        },
        "en-US": {
          whats_new: "Tap the Machtblick logo to jump back to the top."
        }
      }
    )
  rescue => e
    raise unless e.message.include?("Another build is in review")
    UI.important("Build uploaded and processed; external distribution skipped because another build holds the beta review slot. Distribute it in App Store Connect once the queue clears.")
  end

  desc "Submit an existing TestFlight build for App Store review"
  lane :release do |options|
    UI.user_error!("Requested version #{options[:version].inspect} does not match Version.xcconfig MARKETING_VERSION #{APP_VERSION}") unless options[:version] == APP_VERSION

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    build_number = options[:build_number].to_s
    build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "soli.Machtblick",
      version: APP_VERSION
    ).to_s if build_number.empty?

    File.open(ENV["GITHUB_ENV"], "a") do |file|
      file.puts("RELEASE_BUILD_NUMBER=#{build_number}")
    end if ENV["CI"]

    notes = {
      "de-DE" => ENV["WHATS_NEW_DE"].to_s.strip.empty? ? "Verbesserungen und Fehlerbehebungen." : ENV["WHATS_NEW_DE"],
      "en-US" => ENV["WHATS_NEW_EN"].to_s.strip.empty? ? "Improvements and bug fixes." : ENV["WHATS_NEW_EN"]
    }
    app = Spaceship::ConnectAPI::App.find("soli.Machtblick")
    edit_version = app.get_edit_app_store_version(includes: "appStoreVersionLocalizations")
    UI.user_error!("No editable App Store version found for #{APP_VERSION}") unless edit_version
    UI.user_error!("Editable version is #{edit_version.version_string}, expected #{APP_VERSION}") unless edit_version.version_string == APP_VERSION
    edit_version.get_app_store_version_localizations.each do |localization|
      localization.update(attributes: { whats_new: notes[localization.locale] }) if notes[localization.locale]
    end

    upload_to_app_store(
      api_key: api_key,
      app_identifier: "soli.Machtblick",
      app_version: APP_VERSION,
      build_number: build_number,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      force: true,
      submit_for_review: true,
      automatic_release: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload App Store metadata and screenshots"
  lane :app_store_assets do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: "soli.Machtblick",
      app_version: APP_VERSION,
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "soli.Machtblick",
        version: APP_VERSION
      ).to_s,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      sync_screenshots: true,
      force: true,
      submit_for_review: false,
      automatic_release: true,
      precheck_include_in_app_purchases: false
    )
  end
end
