require "shellwords"

APP_VERSION = File.read(
  File.expand_path("../apps/ios/Config/Version.xcconfig", __dir__)
).match(/^MARKETING_VERSION = (.+)$/)[1]

default_platform(:ios)

platform :ios do
  desc "Build and upload iOS app to TestFlight"
  lane :beta_local do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "soli.Machtblick"
    )
    build_number += 1
    increment_build_number(
      xcodeproj: "apps/ios/iOS.xcodeproj",
      build_number: build_number
    )
    File.open(ENV["GITHUB_ENV"], "a") do |file|
      file.puts("TESTFLIGHT_BUILD_NUMBER=#{build_number}")
    end if ENV["CI"]

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "apps/ios/iOS.xcodeproj",
      team_id: "Q9U8224WWM",
      targets: ["Machtblick"]
    )

    auth_xcargs = ""
    if ENV["CI"]
      key_path = File.join(ENV.fetch("RUNNER_TEMP"), "AuthKey.p8")
      File.write(key_path, ENV["APP_STORE_CONNECT_API_KEY_CONTENT"])
      auth_xcargs = "-authenticationKeyID #{ENV["APP_STORE_CONNECT_API_KEY_ID"]} -authenticationKeyIssuerID #{ENV["APP_STORE_CONNECT_API_ISSUER_ID"]} -authenticationKeyPath #{Shellwords.escape(key_path)}"
    end

    build_app(
      project: "apps/ios/iOS.xcodeproj",
      scheme: "Machtblick",
      xcargs: "-allowProvisioningUpdates #{auth_xcargs}",
      export_method: "app-store",
      export_xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: "Q9U8224WWM"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      distribute_external: true,
      groups: [ENV.fetch("TESTFLIGHT_PUBLIC_GROUP")],
      notify_external_testers: true,
      changelog: "Neu: Machtblick startet im hellen Design. Fraktionsfarben, Abstimmungsstempel und Sitzverteilungen bleiben im dunklen Design klar erkennbar.",
      localized_build_info: {
        "de-DE": {
          whats_new: "Machtblick startet jetzt standardmäßig im hellen Design. Im dunklen Design bleiben Fraktionsfarben, Abstimmungsstempel und Sitzverteilungen deutlich erkennbar."
        },
        "en-US": {
          whats_new: "Machtblick now starts in Light appearance. Party colors, vote stamps, and seat diagrams remain clearly visible in Dark appearance."
        }
      }
    )
  end

  desc "Upload App Store metadata and screenshots"
  lane :app_store_assets do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: "soli.Machtblick",
      app_version: APP_VERSION,
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "soli.Machtblick",
        version: APP_VERSION
      ).to_s,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      sync_screenshots: true,
      force: true,
      submit_for_review: false,
      automatic_release: true,
      precheck_include_in_app_purchases: false
    )
  end
end
