#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${MACHTBLICK_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"

mkdir -p "$UNIT_DIR"

for KIND in service timer; do
  sed "s#__ROOT__#$ROOT#g" "$ROOT/scripts/systemd/machtblick-bundestag-auto-refresh.$KIND.in" > "$UNIT_DIR/machtblick-bundestag-auto-refresh.$KIND"
done

systemctl --user import-environment PATH
systemctl --user daemon-reload

cat <<'EOF'
Installed machtblick-bundestag-auto-refresh user units.

Enable:
systemctl --user enable --now machtblick-bundestag-auto-refresh.timer

Check:
systemctl --user status machtblick-bundestag-auto-refresh.timer
systemctl --user list-timers
journalctl --user -u machtblick-bundestag-auto-refresh.service -n 100

Disable:
systemctl --user disable --now machtblick-bundestag-auto-refresh.timer
EOF
