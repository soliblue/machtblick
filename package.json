{
  "name": "machtblick",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["db", "etl/*", "apps/*"],
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:normalize": "tsx db/normalize-results.ts",
    "etl:donations": "tsx etl/bundestag-spenden/ingest.ts",
    "etl:affiliations": "tsx etl/bundestag-affiliations/ingest.ts",
    "etl:speeches": "tsx etl/bundestag-reden/ingest.ts",
    "etl:speeches:xml:fetch": "tsx etl/bundestag-reden-xml/fetch.ts",
    "etl:speeches:xml:ingest": "tsx etl/bundestag-reden-xml/ingest.ts",
    "etl:speeches:xml": "npm run etl:speeches:xml:fetch && npm run etl:speeches:xml:ingest",
    "etl:stammdaten:fetch": "tsx etl/bundestag-stammdaten/fetch.ts",
    "etl:stammdaten:ingest": "tsx etl/bundestag-stammdaten/ingest.ts",
    "etl:stammdaten": "npm run etl:stammdaten:fetch && npm run etl:stammdaten:ingest",
    "etl:dip:answers:fetch": "tsx etl/dip/answers/fetch.ts",
    "etl:dip:answers:extract": "tsx etl/dip/answers/extract.ts",
    "etl:dip:answers:ingest": "tsx etl/dip/answers/ingest.ts",
    "etl:dip:answers": "npm run etl:dip:answers:fetch && npm run etl:dip:answers:extract && npm run etl:dip:answers:ingest",
    "etl:portraits": "tsx etl/wikidata-portraits/ingest.ts",
    "etl:abgeordnetenwatch": "tsx etl/abgeordnetenwatch-members/ingest.ts",
    "etl:handzeichen:refresh": "node etl/bundestag/handzeichen/refresh.mjs",
    "etl:handzeichen:proposers": "node etl/bundestag/handzeichen/proposers.mjs",
    "etl:polarity": "node etl/bundestag/polarity/run.mjs",
    "etl:initiator": "node etl/bundestag/votes/initiator/run.mjs",
    "etl:descriptions": "node etl/bundestag/descriptions/run.mjs",
    "etl:titles": "node etl/bundestag/titles/run.mjs"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
