{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bundestag: dev",
      "type": "shell",
      "command": "source ~/.nvm/nvm.sh && nvm use --silent && npm run dev -w @machtblick/bundestag",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*Local:\\s+https?://.*"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
