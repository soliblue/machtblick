{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "app",
      "type": "vscode-edge-devtools.debug",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/bundestag",
      "preLaunchTask": "bundestag: dev",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@fs/*": "/*",
        "/src/*": "${workspaceFolder}/apps/bundestag/src/*"
      }
    }
  ],
  "compounds": []
}
